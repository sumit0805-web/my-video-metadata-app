# ─────────────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# OpenAI API key — used by metadata_generator.py to call GPT-4o
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional tuning knobs ──────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower on CPU.
WHISPER_MODEL=base

# Max frames extracted per video (spread evenly across duration)
MAX_FRAMES=10

# Temporary file storage directory (defaults to system temp if unset)
# TEMP_DIR=/tmp/video_metadata
